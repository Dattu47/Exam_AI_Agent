# Copy to .env and adjust as needed.
# Optional: all have defaults in config/settings.py

# Ollama (for AI study plan and optional embeddings)
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=llama2

# Search and scraping
# MAX_SEARCH_RESULTS=10
# MAX_SCRAPE_PAGES=5
# REQUEST_TIMEOUT=15

# Vector store path (relative to project or absolute)
# VECTOR_STORE_PATH=exam_ai_agent/data/faiss_index

# API
# API_PORT=8000

# Logging
# LOG_LEVEL=INFO
